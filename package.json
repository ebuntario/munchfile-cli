{
  "name": "@munchfile/cli",
  "version": "0.1.1",
  "description": "MunchFile CLI — watch local files, share live URLs.",
  "bin": {
    "munchfile": "./dist/index.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://munchfile.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebuntario/munchfile-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ebuntario/munchfile-cli/issues"
  },
  "keywords": [
    "cli",
    "file-sharing",
    "markdown",
    "watch",
    "live-reload",
    "static-hosting"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist bin",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "compile:darwin-arm64": "bun build --compile --minify --sourcemap --target=bun-darwin-arm64 ./src/index.ts --outfile bin/munchfile-darwin-arm64",
    "compile:darwin-x64": "bun build --compile --minify --sourcemap --target=bun-darwin-x64 ./src/index.ts --outfile bin/munchfile-darwin-x64",
    "compile:linux-x64": "bun build --compile --minify --sourcemap --target=bun-linux-x64 ./src/index.ts --outfile bin/munchfile-linux-x64",
    "compile:linux-arm64": "bun build --compile --minify --sourcemap --target=bun-linux-arm64 ./src/index.ts --outfile bin/munchfile-linux-arm64",
    "compile:all": "npm run compile:darwin-arm64 && npm run compile:darwin-x64 && npm run compile:linux-x64 && npm run compile:linux-arm64"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "clime": "^0.3.0",
    "node-fetch": "^3.3.2",
    "yaml": "^2.4.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
